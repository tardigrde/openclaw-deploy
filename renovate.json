{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "dependencies"
  ],
  "schedule": [
    "every weekend"
  ],
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "description": "Group GitHub Actions updates — low-risk, auto-merge",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Never auto-merge OpenClaw: check release notes and run backup-now first",
      "matchPackageNames": [
        "openclaw"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "openclaw-upgrade"
      ]
    },
    {
      "description": "Suppress tflint-ruleset-hcloud lookup — Renovate cannot resolve github-releases for this package",
      "matchPackageNames": [
        "terraform-linters/tflint-ruleset-hcloud"
      ],
      "enabled": false
    },
    {
      "description": "Suppress false go detection in pages.yml (HUGO_VERSION misidentified as go)",
      "matchFileNames": [
        ".github/workflows/pages.yml"
      ],
      "matchPackageNames": [
        "go"
      ],
      "enabled": false
    },
    {
      "description": "Group Docker base image updates for manual review",
      "matchManagers": [
        "dockerfile",
        "docker-compose"
      ],
      "groupName": "Docker base images",
      "automerge": false
    },
    {
      "description": "Group Terraform provider and CLI updates for manual review",
      "matchManagers": [
        "terraform",
        "github-actions"
      ],
      "matchPackageNames": [
        "hashicorp/terraform"
      ],
      "groupName": "Terraform",
      "automerge": false
    },
    {
      "description": "Group SOPS updates (Dockerfile + CI examples) for manual review before applying",
      "matchPackageNames": [
        "getsops/sops"
      ],
      "groupName": "SOPS",
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "description": "Track OpenClaw version pinned via Dockerfile ARG",
      "customType": "regex",
      "managerFilePatterns": [
        "/^docker/Dockerfile$/"
      ],
      "matchStrings": [
        "ARG OPENCLAW_VERSION=(?<currentValue>[\\d]+\\.[\\d]+\\.[\\d]+)"
      ],
      "depNameTemplate": "openclaw",
      "datasourceTemplate": "npm",
      "versioningTemplate": "npm"
    },
    {
      "description": "Track notesmd-cli binary release referenced in Dockerfile download URL",
      "customType": "regex",
      "managerFilePatterns": [
        "/^docker/Dockerfile$/"
      ],
      "matchStrings": [
        "ARG NOTESMD_CLI_VERSION=(?<currentValue>[\\d]+\\.[\\d]+\\.[\\d]+)"
      ],
      "depNameTemplate": "Yakitrak/notesmd-cli",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "description": "Track Mission Control version pinned in Ansible plays",
      "customType": "regex",
      "managerFilePatterns": [
        "/^ansible/plays/docker\\.yml$/",
        "/^ansible/deploy\\.yml$/"
      ],
      "matchStrings": [
        "crshdn/mission-control\\.git[\\s\\S]*?version: v?(?<currentValue>[\\d]+\\.[\\d]+\\.[\\d]+)"
      ],
      "depNameTemplate": "crshdn/mission-control",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "description": "Track SOPS binary release referenced in Dockerfile",
      "customType": "regex",
      "managerFilePatterns": [
        "/^docker/Dockerfile$/"
      ],
      "matchStrings": [
        "ARG SOPS_VERSION=(?<currentValue>[\\d]+\\.[\\d]+(?:\\.[\\d]+)?)"
      ],
      "depNameTemplate": "getsops/sops",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "description": "Track Hugo version pinned as env var in pages.yml",
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/pages\\.yml$/"
      ],
      "matchStrings": [
        "HUGO_VERSION: (?<currentValue>[\\d]+\\.[\\d]+\\.[\\d]+)"
      ],
      "depNameTemplate": "gohugoio/hugo",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "description": "Track lossless-claw npm plugin pinned in entrypoint.sh",
      "customType": "regex",
      "managerFilePatterns": [
        "/^docker/entrypoint\\.sh$/"
      ],
      "matchStrings": [
        "@martian-engineering/lossless-claw@(?<currentValue>[\\d]+\\.[\\d]+\\.[\\d]+)"
      ],
      "depNameTemplate": "@martian-engineering/lossless-claw",
      "datasourceTemplate": "npm"
    },
    {
      "description": "Track SOPS binary release in CI workflows and Ansible config play (verified via cosign)",
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/[^/]+\\.yml$/",
        "/^ansible/plays/config\\.yml$/"
      ],
      "matchStrings": [
        "SOPS_VERSION=(?<currentValue>[\\d]+\\.[\\d]+(?:\\.[\\d]+)?)"
      ],
      "depNameTemplate": "getsops/sops",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "description": "Track cosign binary release in Ansible config play",
      "customType": "regex",
      "managerFilePatterns": [
        "/^ansible/plays/config\\.yml$/"
      ],
      "matchStrings": [
        "COSIGN_VERSION=(?<currentValue>[\\d]+\\.[\\d]+(?:\\.[\\d]+)?)"
      ],
      "depNameTemplate": "sigstore/cosign",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "description": "Track ansible-core lower bound in GitHub Actions workflows (range: >=X.Y,<Z)",
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/[^/]+\\.yml$/"
      ],
      "matchStrings": [
        "pip install \"ansible-core>=(?<currentValue>[\\d]+\\.[\\d]+(?:\\.[\\d]+)?),<[\\d]+\""
      ],
      "depNameTemplate": "ansible-core",
      "datasourceTemplate": "pypi",
      "versioningTemplate": "pep440"
    },
    {
      "description": "Track Hugo version in docs workflow",
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/pages\\.yml$/"
      ],
      "matchStrings": [
        "HUGO_VERSION: (?<currentValue>[\\d]+\\.[\\d]+(?:\\.[\\d]+)?)"
      ],
      "depNameTemplate": "gohugoio/hugo",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "description": "Track Dart Sass version in docs workflow",
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/pages\\.yml$/"
      ],
      "matchStrings": [
        "DART_SASS_VERSION: (?<currentValue>[\\d]+\\.[\\d]+(?:\\.[\\d]+)?)"
      ],
      "depNameTemplate": "sass/dart-sass",
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "Track Go version in docs workflow",
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/pages\\.yml$/"
      ],
      "matchStrings": [
        "GO_VERSION: (?<currentValue>[\\d]+\\.[\\d]+(?:\\.[\\d]+)?)"
      ],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version"
    },
    {
      "description": "Track Node.js version in docs workflow",
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/pages\\.yml$/"
      ],
      "matchStrings": [
        "NODE_VERSION: (?<currentValue>[\\d]+\\.[\\d]+(?:\\.[\\d]+)?)"
      ],
      "depNameTemplate": "node",
      "datasourceTemplate": "node-version"
    },
    {
      "description": "Track uv (Python package manager) version pinned via Dockerfile ARG",
      "customType": "regex",
      "managerFilePatterns": [
        "/^docker/Dockerfile$/"
      ],
      "matchStrings": [
        "ARG UV_VERSION=(?<currentValue>[\\d]+\\.[\\d]+(?:\\.[\\d]+)?)"
      ],
      "depNameTemplate": "astral-sh/uv",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "description": "Track npm package versions pinned via Dockerfile ARG (clawhub, ws)",
      "customType": "regex",
      "managerFilePatterns": [
        "/^docker/Dockerfile$/"
      ],
      "matchStrings": [
        "ARG (?<depNamePart>CLAWHUB|WS)_VERSION=(?<currentValue>[\\d]+\\.[\\d]+(?:\\.[\\d]+)?)"
      ],
      "depNameTemplate": "{{#lower}}{{{depNamePart}}}{{/lower}}",
      "datasourceTemplate": "npm",
      "versioningTemplate": "npm"
    },
    {
      "description": "Track @steipete/summarize version pinned via Dockerfile ARG",
      "customType": "regex",
      "managerFilePatterns": [
        "/^docker/Dockerfile$/"
      ],
      "matchStrings": [
        "ARG SUMMARIZE_VERSION=(?<currentValue>[\\d]+\\.[\\d]+(?:\\.[\\d]+)?)"
      ],
      "depNameTemplate": "@steipete/summarize",
      "datasourceTemplate": "npm",
      "versioningTemplate": "npm"
    },
    {
      "description": "Track cosign sidecar image version in Dockerfile COPY --from (same depName as Ansible cosign, so PRs batch together)",
      "customType": "regex",
      "managerFilePatterns": [
        "/^docker/Dockerfile$/"
      ],
      "matchStrings": [
        "gcr\\.io/projectsigstore/cosign:v(?<currentValue>[\\d]+\\.[\\d]+(?:\\.[\\d]+)?)"
      ],
      "depNameTemplate": "sigstore/cosign",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "description": "Track python-semantic-release lower bound in release workflow",
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/release\\.yml$/"
      ],
      "matchStrings": [
        "pip install 'python-semantic-release>=(?<currentValue>[\\d]+(?:\\.[\\d]+(?:\\.[\\d]+)?)?),<[\\d]+'"
      ],
      "depNameTemplate": "python-semantic-release",
      "datasourceTemplate": "pypi",
      "versioningTemplate": "pep440"
    },
    {
      "description": "Track Terraform CLI version pinned in CI workflows (setup-terraform action input)",
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/[^/]+\\.yml$/"
      ],
      "matchStrings": [
        "terraform_version: \"(?<currentValue>[\\d]+\\.[\\d]+(?:\\.[\\d]+)?)\""
      ],
      "depNameTemplate": "hashicorp/terraform",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    }
  ]
}
