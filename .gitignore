# =============================================================================
# Terraform
# =============================================================================

# Local .terraform directories
.terraform/
.terraform.lock.hcl

# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Variable files (may contain secrets)
*.tfvars
!*.tfvars.example

# Backend config (personal — copy from backend.tf.example)
backend.tf
!backend.tf.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files
*.tfplan
tfplan

# =============================================================================
# Secrets and Credentials
# =============================================================================

# SSH private keys
*.pem
*.key
id_rsa
id_ed25519

# Environment files
.env
.env.*
!.env.example

# Secrets directory (real env files with API keys)
secrets/*
!secrets/*.example*
# Age key — NEVER commit this
secrets/age-key.txt
# SOPS-encrypted secrets are safe to commit
#!secrets/*.enc

# OpenClaw config (create from openclaw.example.json)
openclaw.json

# =============================================================================
# IDE and Editor
# =============================================================================

# VSCode
.vscode/
*.code-workspace

# JetBrains
.idea/

# Vim
*.swp
*.swo
*~

# =============================================================================
# OS Generated
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# =============================================================================
# Backups
# =============================================================================

*.backup
*.bak
*.old

# Local backup downloads (from make backup-pull)
backups/


.claude/worktrees/
.claude/settings.local.json

# =============================================================================
# Local Overrides (personal/addon customizations — see *.example counterparts)
# =============================================================================

docker-compose.override.yml
Makefile.local
ansible/site.local.yml
ansible/plays/*.local.yml
scripts/local/
docs/local/
.github/workflows/deploy.yml
.github/workflows/rollback.yml

# Hugo build output
public/
resources/
.hugo_build.lock

# Copied in CI — do not commit
docs/index.md
docs/security.md
