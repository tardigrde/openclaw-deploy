# Copy to Makefile.local (gitignored, auto-loaded by Makefile).
# All variables from the main Makefile are available (SERVER_IP, SSH_KEY, etc.).

.PHONY: patch-devices addon-weather

patch-devices: ## Fix all device pairing issues (CLI scopes + UI pairing)
	@echo -e "$(BLUE)[AUTH]$(NC) Patching all device settings on VPS..."
	@$(ANSIBLE) $(PLAYBOOK) --tags patch_devices

addon-weather: ## Install morning-weather cron on VPS
	@echo -e "$(BLUE)[ADDON]$(NC) Installing morning-weather cron..."
	@$(ANSIBLE) $(PLAYBOOK) --tags addon-weather-report
